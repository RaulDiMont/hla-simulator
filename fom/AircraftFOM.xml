<?xml version="1.0" encoding="UTF-8"?>
<objectModel xsi:type="dataModelType"
             xmlns="http://standards.ieee.org/IEEE1516-2010"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <!-- Federation name -->
    <modelIdentification>
        <name>AircraftSimulation</name>
        <type>FOM</type>
        <version>1.0</version>
        <purpose>Basic aircraft position simulation</purpose>
    </modelIdentification>

    <!-- Object classes shared across federates -->
    <objects>
        <objectClass>
            <name>HLAobjectRoot</name>
            <objectClass>
                <name>Aircraft</name>
                <!-- Geographic position of the aircraft -->
                <attribute>
                    <name>Latitude</name>
                    <dataType>HLAfloat64BE</dataType>
                    <updateType>Periodic</updateType>
                    <ownership>DivestAcquire</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <transportation>HLAreliable</transportation>
                    <order>Receive</order>
                </attribute>
                <attribute>
                    <name>Longitude</name>
                    <dataType>HLAfloat64BE</dataType>
                    <updateType>Periodic</updateType>
                    <ownership>DivestAcquire</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <transportation>HLAreliable</transportation>
                    <order>Receive</order>
                </attribute>
                <attribute>
                    <name>Altitude</name>
                    <dataType>HLAfloat64BE</dataType>
                    <updateType>Periodic</updateType>
                    <ownership>DivestAcquire</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <transportation>HLAreliable</transportation>
                    <order>Receive</order>
                </attribute>
            </objectClass>
        </objectClass>
    </objects>

</objectModel>